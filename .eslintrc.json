{
	"extends": ["next/core-web-vitals", "next/typescript", "plugin:prettier/recommended"],
	"rules": {
		"react/react-in-jsx-scope": "off",
		"@typescript-eslint/no-explicit-any": "off",
		"@typescript-eslint/no-unused-expressions": "off",
		"import/extensions": [
			"error",
			"ignorePackages",
			{
				"ts": "never",
				"tsx": "never",
				"js": "never",
				"jsx": "never"
			}
		]
	}
}
